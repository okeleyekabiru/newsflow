# Copy to .env.local and fill in values for local development.
#
# How the API proxy works
# ──────────────────────
# api.ts uses NEXT_PUBLIC_API_URL as the fetch base URL.
# When it is empty, all API calls use relative paths (/api/...) which are
# intercepted by the Next.js rewrites() in next.config.mjs and forwarded to
# INTERNAL_API_URL on the server side.
#
# In Docker:  INTERNAL_API_URL=http://api:8080  (Docker service name)
# Locally:    INTERNAL_API_URL=http://localhost:5000

# Leave empty so the Next.js rewrite proxy is used (no CORS required)
NEXT_PUBLIC_API_URL=

# Server-side target for the rewrite proxy
INTERNAL_API_URL=http://localhost:5000

# SignalR hub URL (used by CollaborationHub client)
NEXT_PUBLIC_SIGNALR_URL=http://localhost:5000/hubs/collaboration
